{
  "version": "1.0.0",
  "layout_name": "mypage/change-password",
  "extends": "mypage/_mypage_base",
  "init_actions": [
    {
      "handler": "setState",
      "params": {
        "target": "local",
        "isSubmitting": false,
        "submitError": null,
        "submitErrors": null,
        "success": false
      }
    }
  ],
  "slots": {
    "mypage_body": [
      {
        "type": "basic",
        "name": "Div",
        "if": "{{_local.success}}",
        "props": {
          "className": "ac_form_message is_success"
        },
        "children": [
          {"type": "basic", "name": "P", "text": "Password changed successfully."}
        ]
      },
      {
        "type": "basic",
        "name": "Div",
        "if": "{{_local.submitError}}",
        "props": {
          "className": "ac_form_message is_error"
        },
        "children": [
          {"type": "basic", "name": "P", "text": "{{_local.submitError}}"}
        ]
      },
      {
        "type": "basic",
        "name": "Form",
        "dataKey": "form",
        "if": "{{!_local.success}}",
        "props": {
          "className": "ac_form_stack"
        },
        "actions": [
          {
            "type": "submit",
            "handler": "sequence",
            "actions": [
              {
                "handler": "setState",
                "params": {
                  "target": "local",
                  "isSubmitting": true,
                  "submitError": null,
                  "submitErrors": null
                }
              },
              {
                "handler": "apiCall",
                "auth_required": true,
                "target": "/api/me/password",
                "params": {
                  "method": "PUT",
                  "body": {
                    "current_password": "{{form.current_password}}",
                    "password": "{{form.password}}",
                    "password_confirmation": "{{form.password_confirmation}}"
                  }
                },
                "onSuccess": [
                  {
                    "handler": "setState",
                    "params": {
                      "target": "local",
                      "isSubmitting": false,
                      "submitErrors": null,
                      "success": true
                    }
                  },
                  {
                    "handler": "toast",
                    "params": {
                      "type": "success",
                      "message": "Password changed successfully."
                    }
                  }
                ],
                "onError": [
                  {
                    "handler": "setState",
                    "params": {
                      "target": "local",
                      "isSubmitting": false,
                      "submitError": "{{error.errors?.current_password ? 'Enter your current password.' : error.errors?.password ? 'Check your new password and confirmation.' : 'Unable to change your password.'}}",
                      "submitErrors": "{{error.errors}}"
                    }
                  }
                ]
              }
            ]
          }
        ],
        "children": [
          {
            "type": "basic",
            "name": "Div",
            "props": {
              "className": "ac_field"
            },
            "children": [
              {"type": "basic", "name": "Label", "text": "Current Password"},
              {"type": "basic", "name": "Input", "props": {"type": "password", "name": "current_password", "placeholder": "Current password", "className": "ac_input", "required": true, "disabled": "{{_local.isSubmitting}}"}},
              {"type": "basic", "name": "P", "if": "{{_local.submitErrors?.current_password}}", "props": {"className": "ac_field_error"}, "text": "Enter your current password."}
            ]
          },
          {
            "type": "basic",
            "name": "Div",
            "props": {
              "className": "ac_field_grid"
            },
            "children": [
              {"type": "basic", "name": "Div", "props": {"className": "ac_field"}, "children": [{"type": "basic", "name": "Label", "text": "New Password"}, {"type": "basic", "name": "Input", "props": {"type": "password", "name": "password", "placeholder": "Minimum 8 characters", "className": "ac_input", "required": true, "disabled": "{{_local.isSubmitting}}"}}, {"type": "basic", "name": "P", "if": "{{_local.submitErrors?.password}}", "props": {"className": "ac_field_error"}, "text": "Password must be at least 8 characters and match the confirmation field."}]},
              {"type": "basic", "name": "Div", "props": {"className": "ac_field"}, "children": [{"type": "basic", "name": "Label", "text": "Confirm Password"}, {"type": "basic", "name": "Input", "props": {"type": "password", "name": "password_confirmation", "placeholder": "Repeat new password", "className": "ac_input", "required": true, "disabled": "{{_local.isSubmitting}}"}}, {"type": "basic", "name": "P", "if": "{{_local.submitErrors?.password_confirmation}}", "props": {"className": "ac_field_error"}, "text": "Password confirmation does not match."}]}
            ]
          },
          {
            "type": "basic",
            "name": "Button",
            "props": {
              "type": "submit",
              "className": "ac_submit_button",
              "disabled": "{{_local.isSubmitting}}"
            },
            "text": "{{_local.isSubmitting ? 'Updating...' : 'Change Password'}}"
          }
        ]
      },
      {
        "type": "basic",
        "name": "Div",
        "if": "{{_local.success}}",
        "props": {
          "className": "ac_auth_footer_links"
        },
        "children": [
          {"type": "basic", "name": "Span", "text": "Return to your account page."},
          {
            "type": "basic",
            "name": "Button",
            "props": {
              "type": "button",
              "className": "ac_inline_button"
            },
            "text": "Account",
            "actions": [
              {
                "type": "click",
                "handler": "navigate",
                "params": {
                  "path": "/mypage/profile"
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
