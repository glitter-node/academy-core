{
  "version": "1.0.0",
  "layout_name": "_user_base",
  "meta": {
    "title": "$t:common.base.layout_title",
    "description": "$t:common.base.layout_description",
    "is_base": true
  },
  "globalHeaders": [
    {
      "pattern": "/api/*",
      "headers": {
        "X-Template-Identifier": "academy-core",
        "Accept-Language": "{{_global.currentLocale ?? 'en'}}"
      }
    }
  ],
  "transition_overlay": {
    "enabled": true,
    "style": "spinner",
    "target": "ac_main"
  },
  "init_actions": [
    {
      "handler": "setState",
      "params": {
        "target": "global",
        "templateId": "academy-core",
        "currentLocale": "{{query.locale ?? 'en'}}"
      }
    },
    {
      "handler": "initTheme"
    }
  ],
  "initLocal": {
    "headerMenuOpen": false,
    "headerDesktopMenu": ""
  },
  "components": [
    {
      "id": "ac_shell",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "ac_shell"
      },
      "children": [
        {
          "partial": "partials/common/_site_header.json"
        },
        {
          "id": "ac_main",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "ac_main"
          },
          "children": [
            {
              "id": "ac_main_wrap",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "ac_wrap"
              },
              "children": [
                {
                  "id": "ac_main_slot",
                  "type": "basic",
                  "name": "Div",
                  "slot": "content",
                  "children": []
                }
              ]
            }
          ]
        },
        {
          "partial": "partials/common/_site_footer.json"
        }
      ]
    }
  ]
}
