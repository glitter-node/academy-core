{
  "version": "1.0.0",
  "layout_name": "auth/reset-password",
  "extends": "auth/_auth_base",
  "data_sources": [
    {
      "id": "tokenValidation",
      "type": "api",
      "endpoint": "/api/auth/validate-reset-token",
      "method": "POST",
      "auto_fetch": true,
      "auth_required": false,
      "params": {
        "token": "{{query.token ?? ''}}",
        "email": "{{query.email ?? ''}}"
      },
      "loading_strategy": "blocking",
      "initLocal": {
        "tokenValid": "{{data.valid ?? false}}"
      },
      "errorHandling": {
        "422": {
          "handler": "setState",
          "params": {
            "target": "local",
            "tokenError": true
          }
        },
        "default": {
          "handler": "setState",
          "params": {
            "target": "local",
            "tokenError": true
          }
        }
      }
    }
  ],
  "init_actions": [
    {
      "handler": "setState",
      "params": {
        "target": "local",
        "isSubmitting": false,
        "success": false,
        "tokenError": false,
        "resetError": null,
        "errors": null,
        "resetForm.email": "{{query.email ?? ''}}",
        "resetForm.token": "{{query.token ?? ''}}"
      }
    }
  ],
  "slots": {
    "auth_body": [
      {
        "type": "basic",
        "name": "Div",
        "if": "{{_local.resetError && !_local.tokenError && !_local.success}}",
        "props": {
          "className": "ac_form_message is_error"
        },
        "children": [
          {
            "type": "basic",
            "name": "P",
            "text": "{{_local.resetError}}"
          }
        ]
      },
      {
        "type": "basic",
        "name": "Div",
        "if": "{{_local.tokenError}}",
        "props": {
          "className": "ac_status_card ac_status_error ac_auth_notice"
        },
        "children": [
          {
            "type": "basic",
            "name": "P",
            "text": "This password reset link is invalid or has expired. Request a new reset email to continue."
          },
          {
            "type": "basic",
            "name": "Button",
            "props": {
              "type": "button",
              "className": "ac_inline_button ac_auth_notice_action"
            },
            "text": "Request a new reset link",
            "actions": [
              {
                "type": "click",
                "handler": "navigate",
                "params": {
                  "path": "/forgot-password"
                }
              }
            ]
          }
        ]
      },
      {
        "type": "basic",
        "name": "Div",
        "if": "{{_local.success && !_local.tokenError}}",
        "props": {
          "className": "ac_form_message is_success"
        },
        "children": [
          {
            "type": "basic",
            "name": "P",
            "text": "Your password has been reset. You can now sign in with your new password."
          },
          {
            "type": "basic",
            "name": "Button",
            "props": {
              "type": "button",
              "className": "ac_inline_button ac_auth_notice_action"
            },
            "text": "Back to login",
            "actions": [
              {
                "type": "click",
                "handler": "navigate",
                "params": {
                  "path": "/login"
                }
              }
            ]
          }
        ]
      },
      {
        "type": "basic",
        "name": "P",
        "if": "{{!_local.tokenError && !_local.success}}",
        "props": {
          "className": "ac_auth_help"
        },
        "text": "Confirm the account email from your reset link and choose a new password."
      },
      {
        "type": "basic",
        "name": "Form",
        "if": "{{!_local.tokenError && !_local.success}}",
        "dataKey": "resetForm",
        "props": {
          "className": "ac_form_stack ac_form_stack_login"
        },
        "actions": [
          {
            "type": "submit",
            "handler": "sequence",
            "actions": [
              {
                "handler": "setState",
                "params": {
                  "target": "local",
                  "isSubmitting": true,
                  "resetError": null,
                  "errors": null
                }
              },
              {
                "handler": "apiCall",
                "target": "/api/auth/reset-password",
                "params": {
                  "method": "POST",
                  "body": {
                    "token": "{{resetForm.token ?? query.token ?? ''}}",
                    "email": "{{resetForm.email ?? query.email ?? ''}}",
                    "password": "{{resetForm.password}}",
                    "password_confirmation": "{{resetForm.password_confirmation}}"
                  }
                },
                "onSuccess": [
                  {
                    "handler": "setState",
                    "params": {
                      "target": "local",
                      "isSubmitting": false,
                      "success": true,
                      "resetError": null,
                      "errors": null
                    }
                  },
                  {
                    "handler": "toast",
                    "params": {
                      "type": "success",
                      "message": "Password reset completed."
                    }
                  }
                ],
                "onError": [
                  {
                    "handler": "setState",
                    "params": {
                      "target": "local",
                      "isSubmitting": false,
                      "resetError": "{{error.errors?.token ? 'This password reset link is invalid or has expired.' : error.errors?.password ? 'Check your new password and confirmation.' : error.errors?.email ? 'The email address does not match this reset request.' : 'Unable to reset your password.'}}",
                      "errors": "{{error.errors}}"
                    }
                  }
                ]
              }
            ]
          }
        ],
        "children": [
          {
            "type": "basic",
            "name": "Div",
            "props": {
              "className": "ac_field"
            },
            "children": [
              {
                "type": "basic",
                "name": "Label",
                "text": "Email"
              },
              {
                "type": "basic",
                "name": "Input",
                "props": {
                  "type": "email",
                  "name": "email",
                  "className": "ac_input",
                  "required": true,
                  "readOnly": true,
                  "disabled": "{{_local.isSubmitting}}"
                }
              },
              {
                "type": "basic",
                "name": "P",
                "if": "{{_local.errors?.email}}",
                "props": {
                  "className": "ac_field_error"
                },
                "text": "The email address does not match this reset request."
              }
            ]
          },
          {
            "type": "basic",
            "name": "Div",
            "props": {
              "className": "ac_field"
            },
            "children": [
              {
                "type": "basic",
                "name": "Label",
                "text": "New password"
              },
              {
                "type": "basic",
                "name": "Input",
                "props": {
                  "type": "password",
                  "name": "password",
                  "placeholder": "Minimum 8 characters",
                  "className": "ac_input",
                  "required": true,
                  "disabled": "{{_local.isSubmitting}}"
                }
              },
              {
                "type": "basic",
                "name": "P",
                "if": "{{_local.errors?.password}}",
                "props": {
                  "className": "ac_field_error"
                },
                "text": "Password must be at least 8 characters and match the confirmation field."
              }
            ]
          },
          {
            "type": "basic",
            "name": "Div",
            "props": {
              "className": "ac_field"
            },
            "children": [
              {
                "type": "basic",
                "name": "Label",
                "text": "Confirm password"
              },
              {
                "type": "basic",
                "name": "Input",
                "props": {
                  "type": "password",
                  "name": "password_confirmation",
                  "placeholder": "Repeat your new password",
                  "className": "ac_input",
                  "required": true,
                  "disabled": "{{_local.isSubmitting}}"
                }
              },
              {
                "type": "basic",
                "name": "P",
                "if": "{{_local.errors?.password_confirmation}}",
                "props": {
                  "className": "ac_field_error"
                },
                "text": "Password confirmation does not match."
              }
            ]
          },
          {
            "type": "basic",
            "name": "Button",
            "props": {
              "type": "submit",
              "className": "{{_local.isSubmitting ? 'ac_submit_button is_loading' : 'ac_submit_button'}}",
              "disabled": "{{_local.isSubmitting}}"
            },
            "children": [
              {
                "type": "basic",
                "name": "Span",
                "if": "{{!_local.isSubmitting}}",
                "props": {
                  "className": "ac_submit_button_label"
                },
                "text": "Reset password"
              },
              {
                "type": "basic",
                "name": "Span",
                "if": "{{_local.isSubmitting}}",
                "props": {
                  "className": "ac_submit_button_label"
                },
                "text": "Updating password..."
              }
            ]
          }
        ]
      }
    ]
  }
}
