{
  "version": "1.0.0",
  "layout_name": "auth/forgot-password",
  "extends": "auth/_auth_base",
  "init_actions": [
    {
      "handler": "setState",
      "params": {
        "target": "local",
        "isSubmitting": false,
        "success": false,
        "formError": null,
        "errors": null,
        "form.email": ""
      }
    }
  ],
  "slots": {
    "auth_body": [
      {
        "type": "basic",
        "name": "Div",
        "if": "{{_local.formError}}",
        "props": {
          "className": "ac_form_message is_error"
        },
        "children": [
          {
            "type": "basic",
            "name": "P",
            "text": "{{_local.formError}}"
          }
        ]
      },
      {
        "type": "basic",
        "name": "Div",
        "if": "{{_local.success}}",
        "props": {
          "className": "ac_form_message is_success"
        },
        "children": [
          {
            "type": "basic",
            "name": "P",
            "text": "Password reset instructions have been sent to your email address."
          }
        ]
      },
      {
        "type": "basic",
        "name": "P",
        "props": {
          "className": "ac_auth_help"
        },
        "text": "Enter the email address connected to your academy account to request a reset link."
      },
      {
        "type": "basic",
        "name": "Form",
        "if": "{{!_local.success}}",
        "dataKey": "form",
        "props": {
          "className": "ac_form_stack ac_form_stack_login"
        },
        "actions": [
          {
            "type": "submit",
            "handler": "sequence",
            "actions": [
              {
                "handler": "setState",
                "params": {
                  "target": "local",
                  "isSubmitting": true,
                  "formError": null,
                  "errors": null
                }
              },
              {
                "handler": "apiCall",
                "target": "/api/auth/forgot-password",
                "params": {
                  "method": "POST",
                  "body": "{{form}}"
                },
                "onSuccess": [
                  {
                    "handler": "setState",
                    "params": {
                      "target": "local",
                      "isSubmitting": false,
                      "success": true,
                      "formError": null,
                      "errors": null
                    }
                  },
                  {
                    "handler": "toast",
                    "params": {
                      "type": "success",
                      "message": "Password reset email sent."
                    }
                  }
                ],
                "onError": [
                  {
                    "handler": "setState",
                    "params": {
                      "target": "local",
                      "isSubmitting": false,
                      "formError": "{{error.errors?.email ? 'Enter the email address for your account.' : 'Unable to send the reset link.'}}",
                      "errors": "{{error.errors}}"
                    }
                  }
                ]
              }
            ]
          }
        ],
        "children": [
          {
            "type": "basic",
            "name": "Div",
            "props": {
              "className": "ac_field"
            },
            "children": [
              {
                "type": "basic",
                "name": "Label",
                "text": "Email"
              },
              {
                "type": "basic",
                "name": "Input",
                "props": {
                  "type": "email",
                  "name": "email",
                  "placeholder": "you@example.com",
                  "className": "ac_input",
                  "required": true,
                  "disabled": "{{_local.isSubmitting}}"
                }
              },
              {
                "type": "basic",
                "name": "P",
                "if": "{{_local.errors?.email}}",
                "props": {
                  "className": "ac_field_error"
                },
                "text": "Enter the email address for your account."
              }
            ]
          },
          {
            "type": "basic",
            "name": "Button",
            "props": {
              "type": "submit",
              "className": "{{_local.isSubmitting ? 'ac_submit_button is_loading' : 'ac_submit_button'}}",
              "disabled": "{{_local.isSubmitting}}"
            },
            "children": [
              {
                "type": "basic",
                "name": "Span",
                "if": "{{!_local.isSubmitting}}",
                "props": {
                  "className": "ac_submit_button_label"
                },
                "text": "Send reset link"
              },
              {
                "type": "basic",
                "name": "Span",
                "if": "{{_local.isSubmitting}}",
                "props": {
                  "className": "ac_submit_button_label"
                },
                "text": "Sending..."
              }
            ]
          }
        ]
      }
    ]
  }
}
